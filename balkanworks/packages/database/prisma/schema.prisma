generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum BusinessStatus {
  DRAFT
  PENDING
  VERIFIED
  BLOCKED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactType {
  PHONE
  EMAIL
  MESSAGE
  LOCATION
}

enum NotificationType {
  IMPORTANT
  RECOMMENDATION
  PROMOTION
  SYSTEM
}

enum OfferStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum CategoryType {
  FOOD
  RETAIL
  SERVICES
  EVENTS
  HEALTH
  OTHER
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  phone         String?        @unique
  passwordHash  String         @map("password_hash")
  status        UserStatus     @default(PENDING)
  profile       Profile?
  businesses    Business[]
  roles         UserRole[]
  audits        AuditLog[]
  files         File[]
  notifications Notification[]
  sessions      AuthSession[]
  favorites     Favorite[]
  reviews       Review[]
  events        Event[]
  searches      SearchQuery[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@map("users")
}

model AuthSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  countryId   String?  @map("country_id") @db.Uuid
  cityId      String?  @map("city_id") @db.Uuid
  preferences Json     @default("{}")
  interests   Json     @default("[]")
  language    String?  @default("sr")
  user        User     @relation(fields: [userId], references: [id])
  country     Country? @relation(fields: [countryId], references: [id])
  city        City?    @relation(fields: [cityId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("profiles")
}

model Country {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  currency  String?
  cities    City[]
  profiles  Profile[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("countries")
}

model City {
  id        String             @id @default(uuid()) @db.Uuid
  countryId String             @map("country_id") @db.Uuid
  name      String
  latitude  Float?
  longitude Float?
  country   Country            @relation(fields: [countryId], references: [id])
  profiles  Profile[]
  locations BusinessLocation[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  @@unique([countryId, name])
  @@map("cities")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@map("roles")
}

model Permission {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  roles     RolePermission[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Business {
  id          String             @id @default(uuid()) @db.Uuid
  ownerId     String             @map("owner_id") @db.Uuid
  name        String
  // Nullable during the staged migration; backfill before making this required.
  slug        String?            @unique
  description String?
  logoUrl     String?            @map("logo_url")
  categoryId  String?            @map("category_id") @db.Uuid
  phone       String?
  email       String?
  website     String?
  status      BusinessStatus     @default(DRAFT)
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  owner       User               @relation(fields: [ownerId], references: [id])
  category    Category?          @relation(fields: [categoryId], references: [id])
  locations   BusinessLocation[]
  offers      Offer[]
  services    Service[]
  images      BusinessImage[]
  favorites   Favorite[]
  reviews     Review[]
  views       BusinessView[]
  contacts    ContactEvent[]
  subscriptions Subscription[]
  events      Event[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@index([categoryId, status])
  @@map("businesses")
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  icon      String?
  type      CategoryType
  businesses Business[]
  offers    Offer[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  @@index([type])
  @@map("categories")
}

model Offer {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  categoryId    String?     @map("category_id") @db.Uuid
  title         String
  description   String?
  imageUrl      String?     @map("image_url")
  price         Decimal?    @db.Decimal(12, 2)
  discountPrice Decimal?    @map("discount_price") @db.Decimal(12, 2)
  currency      String      @default("RSD")
  startsAt      DateTime?  @map("starts_at")
  expiresAt     DateTime?  @map("expires_at")
  status        OfferStatus @default(DRAFT)
  business      Business    @relation(fields: [businessId], references: [id])
  category      Category?   @relation(fields: [categoryId], references: [id])
  favorites     Favorite[]
  events        Event[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  @@index([businessId, status])
  @@index([expiresAt, status])
  @@map("offers")
}

model Favorite {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  offerId    String?   @map("offer_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  offer      Offer?    @relation(fields: [offerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@map("favorites")
}

model Review {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  rating     Int
  comment    String?
  status     ReviewStatus @default(PENDING)
  user       User      @relation(fields: [userId], references: [id])
  business   Business  @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([userId, businessId])
  @@index([businessId, createdAt])
  @@map("reviews")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String
  description String?
  priceRange  String?  @map("price_range")
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([businessId])
  @@map("services")
}

model BusinessImage {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  url        String
  type       String?
  orderIndex Int      @default(0) @map("order_index")
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([businessId, orderIndex])
  @@map("business_images")
}

model Event {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  offerId    String?   @map("offer_id") @db.Uuid
  eventType  String    @map("event_type")
  metadata   Json      @default("{}")
  user       User?     @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  offer      Offer?    @relation(fields: [offerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@index([businessId, createdAt])
  @@index([eventType, createdAt])
  @@map("events")
}

model SearchQuery {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  query        String
  location     String?
  resultsCount Int       @default(0) @map("results_count")
  user         User?     @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@map("searches")
}

model BusinessView {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  source     String?
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("business_views")
}

model ContactEvent {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  businessId String      @map("business_id") @db.Uuid
  type       ContactType
  metadata   Json        @default("{}")
  business   Business    @relation(fields: [businessId], references: [id])
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("contact_events")
}

model Subscription {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  plan       String
  status     String
  startedAt  DateTime @map("started_at")
  expiresAt  DateTime? @map("expires_at")
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([businessId, status])
  @@map("subscriptions")
}

model Embedding {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  vector     Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([entityType, entityId])
  @@map("embeddings")
}

model BusinessLocation {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  cityId     String   @map("city_id") @db.Uuid
  address    String?
  latitude   Float?
  longitude  Float?
  business   Business @relation(fields: [businessId], references: [id])
  city       City     @relation(fields: [cityId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("business_locations")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  resourceType String  @map("resource_type")
  resourceId  String?  @map("resource_id")
  payload     Json     @default("{}")
  actor       User?    @relation(fields: [actorUserId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("audit_logs")
}

model File {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  storageKey  String   @unique @map("storage_key")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  owner       User     @relation(fields: [ownerUserId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("files")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?        @map("read_at")
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("notifications")
}
