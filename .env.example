NODE_ENV=development
API_PORT=3001
# PORT is used by managed hosts such as Render. Locally, API_PORT remains the default.
PORT=3001
DATABASE_URL=postgresql://balkanworks:change-me@localhost:5432/balkanworks
REDIS_URL=redis://localhost:6379/0
# Compatibility fallback for the first MVP configuration. Prefer separate secrets below.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=balkanworks-media
DEALS_ENABLED=true
DIGITAL_FLYERS_ENABLED=false
SAVE_FOOD_ENABLED=true
MARKETPLACE_ENABLED=false
WALLET_ENABLED=false
AI_ASSISTANT_ENABLED=false
PARTNER_API_ENABLED=false
# Required before creating partner webhook subscriptions; use a unique 32+ character secret in each environment.
WEBHOOK_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
PARTNER_API_ENVIRONMENT=development
