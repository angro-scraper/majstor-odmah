NODE_ENV=development
API_PORT=3001
# PORT is used by managed hosts such as Render. Locally, API_PORT remains the default.
PORT=3001
WEB_ORIGIN=http://localhost:3000,https://balkan.works,https://www.balkan.works
DATABASE_URL=postgresql://balkanworks:change-me@localhost:5432/balkanworks
REDIS_URL=redis://localhost:6379/0
# Per-process safety fallback. Production must additionally enforce limits at the
# edge/gateway and use shared Redis limits before multiple API instances run.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
# Compatibility fallback for the first MVP configuration. Prefer separate secrets below.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=balkanworks-media
DEALS_ENABLED=true
DIGITAL_FLYERS_ENABLED=false
SAVE_FOOD_ENABLED=true
MARKETPLACE_ENABLED=false
WALLET_ENABLED=false
# Finance stays provider-agnostic. Never put provider API secrets or card data in source control.
PAYMENT_WEBHOOK_SECRET=replace-with-a-unique-32-character-webhook-secret
PLATFORM_COMMISSION_BPS=500
FRAUD_REVIEW_AMOUNT=50000
AI_ASSISTANT_ENABLED=false
PARTNER_API_ENABLED=false
# Super-app modules are independently deployable. Turn them on per environment only after migration and review.
HEALTH_ENABLED=false
AUTO_ENABLED=false
TRAVEL_ENABLED=false
REAL_ESTATE_ENABLED=false
EDUCATION_ENABLED=false
EVENTS_ENABLED=true
COMMUNITY_ENABLED=true
BALKAN_CARD_ENABLED=true
# Analytics stores only an allow-listed metadata schema. Retention must be reviewed
# with legal/compliance before changing it in production.
ANALYTICS_RAW_EVENT_RETENTION_DAYS=365
ANALYTICS_AGGREGATE_RETENTION_DAYS=730
# Required before creating partner webhook subscriptions; use a unique 32+ character secret in each environment.
WEBHOOK_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
PARTNER_API_ENVIRONMENT=development
# Sprint 15 launch scorecard. These are transparent go/no-go targets, never
# evidence that a city has launched. Configure only after selecting a pilot city.
LAUNCH_PILOT_CITY=Beograd
LAUNCH_TARGET_ACTIVE_BUSINESSES=500
LAUNCH_TARGET_REGISTERED_USERS=50000
LAUNCH_TARGET_ACTIVE_OFFERS=1000
LAUNCH_TARGET_VERIFIED_BUSINESS_RATE=60
