FROM node:22-alpine

WORKDIR /workspace

RUN corepack enable

COPY . .

RUN pnpm install --frozen-lockfile \
  && pnpm --filter @balkanworks/database prisma:generate \
  && pnpm --filter @balkanworks/api prisma:generate \
  && pnpm --filter @balkanworks/database build \
  && pnpm --filter @balkanworks/api build

ENV NODE_ENV=production

EXPOSE 3001

CMD ["sh", "-c", "pnpm --filter @balkanworks/database prisma:deploy && pnpm --filter @balkanworks/api start"]
