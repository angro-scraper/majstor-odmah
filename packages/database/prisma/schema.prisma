generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum UserType {
  CONSUMER
  BUSINESS_OWNER
  EMPLOYEE
  ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING
  VERIFIED
  BLOCKED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactType {
  PHONE
  EMAIL
  MESSAGE
  LOCATION
}

enum NotificationType {
  IMPORTANT
  RECOMMENDATION
  PROMOTION
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

enum RewardEventType {
  SAVE_FOOD_RESERVED
  SAVE_FOOD_PICKED_UP
  SAVE_FOOD_REVIEWED
  DEAL_SAVED
  DEAL_SHARED
  BUSINESS_FOLLOWED
  REVIEW_CREATED
  FRIEND_INVITED
  REFERRAL_COMPLETED
  DAILY_CHECK_IN
  CHALLENGE_COMPLETED
}

enum RewardLevel {
  EXPLORER
  LOCAL_HERO
  BALKAN_INSIDER
  BALKAN_AMBASSADOR
}

enum ReferralStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum CategoryType {
  FOOD
  RETAIL
  SERVICES
  EVENTS
  HEALTH
  OTHER
}

enum PartnerCategory {
  FINANCIAL
  TELECOM
  RETAIL
  FOOD
  CITY_GOVERNMENT
  EDUCATION
  LOGISTICS
  TECHNOLOGY
  OTHER
}

enum PartnerLevel {
  BRONZE
  SILVER
  GOLD
  ENTERPRISE
}

enum PartnerStatus {
  PROSPECT
  PILOT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PartnerIntegrationStatus {
  PLANNED
  PILOT
  ACTIVE
  PAUSED
  RETIRED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum LegalDocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  COOKIE_POLICY
  BUSINESS_TERMS
  PARTNER_TERMS
  CONTENT_POLICY
  REVIEW_POLICY
}

enum LegalDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DataSubjectRequestType {
  EXPORT
  ERASURE
  CORRECTION
}

enum DataSubjectRequestStatus {
  PENDING
  IN_REVIEW
  COMPLETED
  REJECTED
  CANCELLED
}

enum FlyerStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SaveFoodPackageStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
  ARCHIVED
}

enum SaveFoodReservationStatus {
  RESERVED
  PICKED_UP
  CANCELLED
  EXPIRED
}

enum ServiceProviderStatus {
  DRAFT
  ACTIVE
  PAUSED
  SUSPENDED
}

enum ServiceRequestStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobType {
  FULL_TIME
  PART_TIME
  SEASONAL
  FREELANCE
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum JobApplicationStatus {
  SUBMITTED
  REVIEWING
  INTERVIEW
  OFFERED
  REJECTED
  HIRED
  WITHDRAWN
}

enum MarketplaceItemStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  ARCHIVED
}

enum ConversationType {
  SERVICE
  JOB
  MARKETPLACE
  GENERAL
}

enum MessageStatus {
  SENT
  READ
  DELETED
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum AdminScopeLevel {
  COUNTRY
  CITY
}

enum SuperAppModuleKey {
  HEALTH
  AUTO
  TRAVEL
  REAL_ESTATE
  EDUCATION
  EVENTS
  COMMUNITY
  BALKAN_CARD
}

// Finance is an accounting and payment-provider integration layer. It does not
// store card details or hold customer funds.
enum WalletStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum WalletTransactionType {
  PAYMENT
  REFUND
  CASHBACK
  REWARD
  WITHDRAWAL
}

enum WalletTransactionStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  BANK
  LOCAL
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}
model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  phone         String?        @unique
  passwordHash  String         @map("password_hash")
  status        UserStatus     @default(PENDING)
  userType      UserType       @default(CONSUMER) @map("user_type")
  phoneVerified Boolean        @default(false) @map("phone_verified")
  emailVerified Boolean        @default(false) @map("email_verified")
  lastLoginAt   DateTime?      @map("last_login_at")
  profile       Profile?
  businesses    Business[]
  roles         UserRole[]
  audits        AuditLog[]
  files         File[]
  notifications Notification[]
  sessions      AuthSession[]
  favorites     Favorite[]
  reviews       Review[]
  events        Event[]
  recommendationEvents RecommendationEvent[]
  searches      SearchQuery[]
  consents      UserConsent[]
  dataRequests  DataSubjectRequest[]
  foodReservations SaveFoodReservation[]
  foodReviews      SaveFoodReview[]
  businessFollows BusinessFollower[]
  rewardBalance   RewardBalance?
  rewardTransactions RewardTransaction[]
  referralsSent   Referral[] @relation("referrals_sent")
  referralReceived Referral[] @relation("referrals_received")
  interests       UserInterest[]
  challengeProgress ChallengeParticipation[]
  contactInquiries ContactInquiry[]
  locations       UserLocation[]
  serviceProvider ServiceProvider?
  serviceRequests ServiceRequest[] @relation("service_request_customer")
  customerBookings Booking[] @relation("booking_customer")
  jobApplications JobApplication[]
  marketplaceItems MarketplaceItem[]
  conversationParticipants ConversationParticipant[]
  sentMessages ConversationMessage[]
  reportsFiled Report[]
  wallet        Wallet?
  customerPayments Payment[] @relation("customer_payments")
  invoices      Invoice[] @relation("invoice_customer")
  adminScopes   AdminScope[] @relation("admin_scope_user")
  healthProfile HealthProfile?
  healthReminders HealthReminder[]
  vehicles Vehicle[]
  communityGroups CommunityGroup[] @relation("community_group_creator")
  communityMemberships CommunityMembership[]
  communityPosts CommunityPost[]
  membershipCard MembershipCard?
  modulePreferences UserModulePreference[]
  propertyListings PropertyListing[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@map("users")
}

model AuthSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  dateOfBirth DateTime? @map("date_of_birth")
  countryId   String?  @map("country_id") @db.Uuid
  cityId      String?  @map("city_id") @db.Uuid
  preferences Json     @default("{}")
  interests   Json     @default("[]")
  language    String?  @default("sr")
  user        User     @relation(fields: [userId], references: [id])
  country     Country? @relation(fields: [countryId], references: [id])
  city        City?    @relation(fields: [cityId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("profiles")
}

model Country {
  id              String       @id @default(uuid()) @db.Uuid
  code            String       @unique @db.VarChar(2)
  name            String
  currency        String?      @db.VarChar(3)
  defaultLanguage String       @default("sr") @map("default_language") @db.VarChar(10)
  timezone        String       @default("Europe/Belgrade") @db.VarChar(64)
  isActive        Boolean      @default(true) @map("is_active")
  cities          City[]
  profiles        Profile[]
  translations    Translation[]
  adminScopes     AdminScope[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  @@map("countries")
}

model City {
  id        String             @id @default(uuid()) @db.Uuid
  countryId String             @map("country_id") @db.Uuid
  name      String
  latitude  Float?
  longitude Float?
  country   Country            @relation(fields: [countryId], references: [id])
  profiles  Profile[]
  locations BusinessLocation[]
  userLocations UserLocation[]
  adminScopes   AdminScope[]
  localEvents   LocalEvent[]
  communityGroups CommunityGroup[]
  travelExperiences TravelExperience[]
  propertyListings PropertyListing[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  @@unique([countryId, name])
  @@map("cities")
}

model UserLocation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  cityId    String   @map("city_id") @db.Uuid
  latitude  Float?
  longitude Float?
  isPrimary Boolean  @default(false) @map("is_primary")
  user      User     @relation(fields: [userId], references: [id])
  city      City     @relation(fields: [cityId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, cityId])
  @@index([userId, isPrimary])
  @@map("user_locations")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@map("roles")
}

model Permission {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  roles     RolePermission[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Business {
  id          String             @id @default(uuid()) @db.Uuid
  ownerId     String             @map("owner_id") @db.Uuid
  name        String
  // Nullable during the staged migration; backfill before making this required.
  slug        String?            @unique
  description String?
  logoUrl     String?            @map("logo_url")
  coverUrl    String?            @map("cover_url")
  socialLinks Json               @default("{}") @map("social_links")
  categoryId  String?            @map("category_id") @db.Uuid
  phone       String?
  email       String?
  website     String?
  openingHours Json              @default("{}") @map("opening_hours")
  status      BusinessStatus     @default(DRAFT)
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  owner       User               @relation(fields: [ownerId], references: [id])
  category    Category?          @relation(fields: [categoryId], references: [id])
  locations   BusinessLocation[]
  offers      Offer[]
  services    Service[]
  images      BusinessImage[]
  favorites   Favorite[]
  followers   BusinessFollower[]
  reviews     Review[]
  views       BusinessView[]
  contacts    ContactEvent[]
  subscriptions Subscription[]
  events      Event[]
  flyers      DigitalFlyer[]
  foodPackages SaveFoodPackage[]
  rewardCatalog RewardsCatalog[]
  serviceProvider ServiceProvider?
  jobs Job[]
  payments Payment[]
  businessTransactions BusinessTransaction[]
  cashbackRules CashbackRule[]
  invoices Invoice[]
  localEvents LocalEvent[]
  travelExperiences TravelExperience[]
  educationCourses EducationCourse[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@index([categoryId, status])
  @@map("businesses")
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  icon      String?
  type      CategoryType
  businesses Business[]
  offers    Offer[]
  userInterests UserInterest[]
  cashbackRules CashbackRule[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  @@index([type])
  @@map("categories")
}

model Offer {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  categoryId    String?     @map("category_id") @db.Uuid
  title         String
  description   String?
  imageUrl      String?     @map("image_url")
  price         Decimal?    @db.Decimal(12, 2)
  discountPrice Decimal?    @map("discount_price") @db.Decimal(12, 2)
  currency      String      @default("RSD")
  startsAt      DateTime?  @map("starts_at")
  expiresAt     DateTime?  @map("expires_at")
  status        OfferStatus @default(DRAFT)
  business      Business    @relation(fields: [businessId], references: [id])
  category      Category?   @relation(fields: [categoryId], references: [id])
  favorites     Favorite[]
  events        Event[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  @@index([businessId, status])
  @@index([expiresAt, status])
  @@map("offers")
}

model Favorite {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  offerId    String?   @map("offer_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  offer      Offer?    @relation(fields: [offerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@map("favorites")
}

model BusinessFollower {
  userId     String   @map("user_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([userId, businessId])
  @@index([businessId, createdAt])
  @@map("business_followers")
}

model Review {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  rating     Int
  comment    String?
  status     ReviewStatus @default(PENDING)
  user       User      @relation(fields: [userId], references: [id])
  business   Business  @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([userId, businessId])
  @@index([businessId, createdAt])
  @@map("reviews")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String
  description String?
  priceRange  String?  @map("price_range")
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([businessId])
  @@map("services")
}

model ServiceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  parentId  String?  @map("parent_id") @db.Uuid
  parent    ServiceCategory? @relation("service_category_tree", fields: [parentId], references: [id])
  children  ServiceCategory[] @relation("service_category_tree")
  providers ServiceProviderCategory[]
  services  ProviderService[]
  requests  ServiceRequest[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([parentId])
  @@map("service_categories")
}

model ServiceProvider {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @unique @map("user_id") @db.Uuid
  businessId      String?               @unique @map("business_id") @db.Uuid
  description     String?
  experienceYears Int                   @default(0) @map("experience_years")
  priceFrom       Decimal?              @map("price_from") @db.Decimal(12, 2)
  currency        String                @default("RSD")
  availability    Json                  @default("{}")
  location        String?
  status          ServiceProviderStatus @default(DRAFT)
  user            User                  @relation(fields: [userId], references: [id])
  business        Business?             @relation(fields: [businessId], references: [id])
  categories      ServiceProviderCategory[]
  services        ProviderService[]
  requests        ServiceRequest[]
  bookings        Booking[]
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")

  @@index([status, location])
  @@map("service_providers")
}

model ServiceProviderCategory {
  providerId String          @map("provider_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  provider   ServiceProvider @relation(fields: [providerId], references: [id])
  category   ServiceCategory @relation(fields: [categoryId], references: [id])

  @@id([providerId, categoryId])
  @@map("service_provider_categories")
}

model ProviderService {
  id          String          @id @default(uuid()) @db.Uuid
  providerId  String          @map("provider_id") @db.Uuid
  categoryId  String          @map("category_id") @db.Uuid
  name        String
  description String?
  priceFrom   Decimal?        @map("price_from") @db.Decimal(12, 2)
  currency    String          @default("RSD")
  isActive    Boolean         @default(true) @map("is_active")
  provider    ServiceProvider @relation(fields: [providerId], references: [id])
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings    Booking[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  @@index([categoryId, isActive])
  @@index([providerId, isActive])
  @@map("provider_services")
}

model ServiceRequest {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  categoryId  String               @map("category_id") @db.Uuid
  providerId  String?              @map("provider_id") @db.Uuid
  description String
  location    String?
  budget      Decimal?             @db.Decimal(12, 2)
  status      ServiceRequestStatus @default(OPEN)
  user        User                 @relation("service_request_customer", fields: [userId], references: [id])
  category    ServiceCategory      @relation(fields: [categoryId], references: [id])
  provider    ServiceProvider?     @relation(fields: [providerId], references: [id])
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  @@index([categoryId, status, createdAt])
  @@index([providerId, status])
  @@map("service_requests")
}

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  serviceId   String        @map("service_id") @db.Uuid
  customerId  String        @map("customer_id") @db.Uuid
  providerId  String        @map("provider_id") @db.Uuid
  scheduledAt DateTime      @map("scheduled_at")
  location    String?
  agreedPrice Decimal?      @map("agreed_price") @db.Decimal(12, 2)
  status      BookingStatus @default(PENDING)
  service     ProviderService @relation(fields: [serviceId], references: [id])
  customer    User          @relation("booking_customer", fields: [customerId], references: [id])
  provider    ServiceProvider @relation(fields: [providerId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  cancelledAt DateTime?     @map("cancelled_at")

  @@index([providerId, scheduledAt])
  @@index([customerId, scheduledAt])
  @@map("bookings")
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @map("business_id") @db.Uuid
  title       String
  description String
  category    String
  location    String?
  salaryMin   Decimal?  @map("salary_min") @db.Decimal(12, 2)
  salaryMax   Decimal?  @map("salary_max") @db.Decimal(12, 2)
  currency    String    @default("EUR")
  type        JobType
  status      JobStatus @default(DRAFT)
  business    Business  @relation(fields: [businessId], references: [id])
  applications JobApplication[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([status, category, createdAt])
  @@index([businessId, status])
  @@map("jobs")
}

model JobApplication {
  id        String               @id @default(uuid()) @db.Uuid
  jobId     String               @map("job_id") @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  message   String?
  resumeUrl String?              @map("resume_url")
  status    JobApplicationStatus @default(SUBMITTED)
  job       Job                  @relation(fields: [jobId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@unique([jobId, userId])
  @@index([userId, createdAt])
  @@map("job_applications")
}

model MarketplaceItem {
  id          String                @id @default(uuid()) @db.Uuid
  sellerId    String                @map("seller_id") @db.Uuid
  title       String
  description String
  price       Decimal               @db.Decimal(12, 2)
  currency    String                @default("RSD")
  category    String
  location    String?
  imageUrls   Json                  @default("[]") @map("image_urls")
  status      MarketplaceItemStatus @default(DRAFT)
  seller      User                  @relation(fields: [sellerId], references: [id])
