generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum UserType {
  CONSUMER
  BUSINESS_OWNER
  EMPLOYEE
  ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING
  VERIFIED
  BLOCKED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactType {
  PHONE
  EMAIL
  MESSAGE
  LOCATION
}

enum NotificationType {
  IMPORTANT
  RECOMMENDATION
  PROMOTION
  SYSTEM
}

enum OfferStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum CategoryType {
  FOOD
  RETAIL
  SERVICES
  EVENTS
  HEALTH
  OTHER
}

enum PartnerCategory {
  FINANCIAL
  TELECOM
  RETAIL
  FOOD
  CITY_GOVERNMENT
  EDUCATION
  LOGISTICS
  TECHNOLOGY
  OTHER
}

enum PartnerLevel {
  BRONZE
  SILVER
  GOLD
  ENTERPRISE
}

enum PartnerStatus {
  PROSPECT
  PILOT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PartnerIntegrationStatus {
  PLANNED
  PILOT
  ACTIVE
  PAUSED
  RETIRED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum LegalDocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  COOKIE_POLICY
  BUSINESS_TERMS
  PARTNER_TERMS
  CONTENT_POLICY
  REVIEW_POLICY
}

enum LegalDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DataSubjectRequestType {
  EXPORT
  ERASURE
  CORRECTION
}

enum DataSubjectRequestStatus {
  PENDING
  IN_REVIEW
  COMPLETED
  REJECTED
  CANCELLED
}

enum FlyerStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SaveFoodPackageStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
  ARCHIVED
}

enum SaveFoodReservationStatus {
  RESERVED
  PICKED_UP
  CANCELLED
  EXPIRED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  phone         String?        @unique
  passwordHash  String         @map("password_hash")
  status        UserStatus     @default(PENDING)
  userType      UserType       @default(CONSUMER) @map("user_type")
  phoneVerified Boolean        @default(false) @map("phone_verified")
  emailVerified Boolean        @default(false) @map("email_verified")
  lastLoginAt   DateTime?      @map("last_login_at")
  profile       Profile?
  businesses    Business[]
  roles         UserRole[]
  audits        AuditLog[]
  files         File[]
  notifications Notification[]
  sessions      AuthSession[]
  favorites     Favorite[]
  reviews       Review[]
  events        Event[]
  searches      SearchQuery[]
  consents      UserConsent[]
  dataRequests  DataSubjectRequest[]
  foodReservations SaveFoodReservation[]
  businessFollows BusinessFollower[]
  contactInquiries ContactInquiry[]
  locations       UserLocation[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@map("users")
}

model AuthSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  dateOfBirth DateTime? @map("date_of_birth")
  countryId   String?  @map("country_id") @db.Uuid
  cityId      String?  @map("city_id") @db.Uuid
  preferences Json     @default("{}")
  interests   Json     @default("[]")
  language    String?  @default("sr")
  user        User     @relation(fields: [userId], references: [id])
  country     Country? @relation(fields: [countryId], references: [id])
  city        City?    @relation(fields: [cityId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("profiles")
}

model Country {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  currency  String?
  cities    City[]
  profiles  Profile[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("countries")
}

model City {
  id        String             @id @default(uuid()) @db.Uuid
  countryId String             @map("country_id") @db.Uuid
  name      String
  latitude  Float?
  longitude Float?
  country   Country            @relation(fields: [countryId], references: [id])
  profiles  Profile[]
  locations BusinessLocation[]
  userLocations UserLocation[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  @@unique([countryId, name])
  @@map("cities")
}

model UserLocation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  cityId    String   @map("city_id") @db.Uuid
  latitude  Float?
  longitude Float?
  isPrimary Boolean  @default(false) @map("is_primary")
  user      User     @relation(fields: [userId], references: [id])
  city      City     @relation(fields: [cityId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, cityId])
  @@index([userId, isPrimary])
  @@map("user_locations")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@map("roles")
}

model Permission {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  roles     RolePermission[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Business {
  id          String             @id @default(uuid()) @db.Uuid
  ownerId     String             @map("owner_id") @db.Uuid
  name        String
  // Nullable during the staged migration; backfill before making this required.
  slug        String?            @unique
  description String?
  logoUrl     String?            @map("logo_url")
  coverUrl    String?            @map("cover_url")
  socialLinks Json               @default("{}") @map("social_links")
  categoryId  String?            @map("category_id") @db.Uuid
  phone       String?
  email       String?
  website     String?
  openingHours Json              @default("{}") @map("opening_hours")
  status      BusinessStatus     @default(DRAFT)
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  owner       User               @relation(fields: [ownerId], references: [id])
  category    Category?          @relation(fields: [categoryId], references: [id])
  locations   BusinessLocation[]
  offers      Offer[]
  services    Service[]
  images      BusinessImage[]
  favorites   Favorite[]
  followers   BusinessFollower[]
  reviews     Review[]
  views       BusinessView[]
  contacts    ContactEvent[]
  subscriptions Subscription[]
  events      Event[]
  flyers      DigitalFlyer[]
  foodPackages SaveFoodPackage[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@index([categoryId, status])
  @@map("businesses")
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  icon      String?
  type      CategoryType
  businesses Business[]
  offers    Offer[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  @@index([type])
  @@map("categories")
}

model Offer {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  categoryId    String?     @map("category_id") @db.Uuid
  title         String
  description   String?
  imageUrl      String?     @map("image_url")
  price         Decimal?    @db.Decimal(12, 2)
  discountPrice Decimal?    @map("discount_price") @db.Decimal(12, 2)
  currency      String      @default("RSD")
  startsAt      DateTime?  @map("starts_at")
  expiresAt     DateTime?  @map("expires_at")
  status        OfferStatus @default(DRAFT)
  business      Business    @relation(fields: [businessId], references: [id])
  category      Category?   @relation(fields: [categoryId], references: [id])
  favorites     Favorite[]
  events        Event[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  @@index([businessId, status])
  @@index([expiresAt, status])
  @@map("offers")
}

model Favorite {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  offerId    String?   @map("offer_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  offer      Offer?    @relation(fields: [offerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@map("favorites")
}

model BusinessFollower {
  userId     String   @map("user_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([userId, businessId])
  @@index([businessId, createdAt])
  @@map("business_followers")
}

model Review {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  rating     Int
  comment    String?
  status     ReviewStatus @default(PENDING)
  user       User      @relation(fields: [userId], references: [id])
  business   Business  @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([userId, businessId])
  @@index([businessId, createdAt])
  @@map("reviews")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String
  description String?
  priceRange  String?  @map("price_range")
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([businessId])
  @@map("services")
}

model BusinessImage {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  url        String
  type       String?
  orderIndex Int      @default(0) @map("order_index")
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([businessId, orderIndex])
  @@map("business_images")
}

model Event {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  offerId    String?   @map("offer_id") @db.Uuid
  eventType  String    @map("event_type")
  metadata   Json      @default("{}")
  user       User?     @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  offer      Offer?    @relation(fields: [offerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@index([businessId, createdAt])
  @@index([eventType, createdAt])
  @@map("events")
}

model SearchQuery {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  query        String
  location     String?
  resultsCount Int       @default(0) @map("results_count")
  user         User?     @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([userId, createdAt])
  @@map("searches")
}

model BusinessView {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  source     String?
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("business_views")
}

model ContactEvent {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  businessId String      @map("business_id") @db.Uuid
  type       ContactType
  metadata   Json        @default("{}")
  business   Business    @relation(fields: [businessId], references: [id])
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("contact_events")
}

model Subscription {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  plan       String
  status     String
  startedAt  DateTime @map("started_at")
  expiresAt  DateTime? @map("expires_at")
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([businessId, status])
  @@map("subscriptions")
}

model Embedding {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  vector     Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([entityType, entityId])
  @@map("embeddings")
}

model BusinessLocation {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  cityId     String   @map("city_id") @db.Uuid
  address    String?
  latitude   Float?
  longitude  Float?
  business   Business @relation(fields: [businessId], references: [id])
  city       City     @relation(fields: [cityId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("business_locations")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  resourceType String  @map("resource_type")
  resourceId  String?  @map("resource_id")
  payload     Json     @default("{}")
  actor       User?    @relation(fields: [actorUserId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("audit_logs")
}

model File {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  storageKey  String   @unique @map("storage_key")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  owner       User     @relation(fields: [ownerUserId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("files")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?        @map("read_at")
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("notifications")
}

model Partner {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  slug           String               @unique
  category       PartnerCategory
  level          PartnerLevel         @default(BRONZE)
  status         PartnerStatus        @default(PROSPECT)
  contactName    String?              @map("contact_name")
  contactEmail   String?              @map("contact_email")
  website        String?
  description    String?
  apiKeys        PartnerApiKey[]
  integrations   PartnerIntegration[]
  apiRequests    PartnerApiRequest[]
  webhooks       PartnerWebhookSubscription[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  @@index([status, level])
  @@index([category, status])
  @@map("partners")
}

model PartnerApiKey {
  id          String             @id @default(uuid()) @db.Uuid
  partnerId   String             @map("partner_id") @db.Uuid
  label       String
  keyPrefix   String             @map("key_prefix")
  keyHash     String             @unique @map("key_hash")
  scopes      Json               @default("[]")
  expiresAt   DateTime?          @map("expires_at")
  lastUsedAt  DateTime?          @map("last_used_at")
  revokedAt   DateTime?          @map("revoked_at")
  partner     Partner            @relation(fields: [partnerId], references: [id])
  requests    PartnerApiRequest[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@index([partnerId, revokedAt])
  @@map("partner_api_keys")
}

model PartnerIntegration {
  id            String                   @id @default(uuid()) @db.Uuid
  partnerId     String                   @map("partner_id") @db.Uuid
  name          String
  integrationType String                 @map("integration_type")
  status        PartnerIntegrationStatus @default(PLANNED)
  scopes        Json                     @default("[]")
  configuration Json                     @default("{}")
  startedAt     DateTime?                @map("started_at")
  partner       Partner                  @relation(fields: [partnerId], references: [id])
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  deletedAt     DateTime?                @map("deleted_at")

  @@index([partnerId, status])
  @@map("partner_integrations")
}

model PartnerApiRequest {
  id          String         @id @default(uuid()) @db.Uuid
  partnerId   String         @map("partner_id") @db.Uuid
  apiKeyId    String?        @map("api_key_id") @db.Uuid
  endpoint    String
  statusCode  Int            @map("status_code")
  partner     Partner        @relation(fields: [partnerId], references: [id])
  apiKey      PartnerApiKey? @relation(fields: [apiKeyId], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([partnerId, createdAt])
  @@map("partner_api_requests")
}

model PartnerWebhookSubscription {
  id                     String        @id @default(uuid()) @db.Uuid
  partnerId              String        @map("partner_id") @db.Uuid
  endpointUrl            String        @map("endpoint_url")
  eventTypes             Json          @default("[]") @map("event_types")
  signingSecretEncrypted String        @map("signing_secret_encrypted")
  status                 WebhookStatus @default(ACTIVE)
  lastFailureAt          DateTime?     @map("last_failure_at")
  partner                Partner       @relation(fields: [partnerId], references: [id])
  deliveries             PartnerWebhookDelivery[]
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")

  @@index([partnerId, status])
  @@map("partner_webhook_subscriptions")
}

model PartnerWebhookDelivery {
  id             String                 @id @default(uuid()) @db.Uuid
  subscriptionId String                 @map("subscription_id") @db.Uuid
  eventType      String                 @map("event_type")
  payload        Json                   @default("{}")
  status         WebhookDeliveryStatus  @default(PENDING)
  attempts       Int                    @default(0)
  responseStatus Int?                   @map("response_status")
  errorCode      String?                @map("error_code")
  deliveredAt    DateTime?              @map("delivered_at")
  subscription   PartnerWebhookSubscription @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@index([subscriptionId, status, createdAt])
  @@map("partner_webhook_deliveries")
}

model LegalDocument {
  id          String              @id @default(uuid()) @db.Uuid
  type        LegalDocumentType
  version     String
  locale      String              @default("sr")
  title       String
  content     String
  status      LegalDocumentStatus @default(DRAFT)
  publishedAt DateTime?           @map("published_at")
  consents    UserConsent[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  @@unique([type, version, locale])
  @@index([type, locale, status])
  @@map("legal_documents")
}

model UserConsent {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  documentId   String        @map("document_id") @db.Uuid
  source       String?
  acceptedAt   DateTime?     @map("accepted_at")
  withdrawnAt  DateTime?     @map("withdrawn_at")
  user         User          @relation(fields: [userId], references: [id])
  document     LegalDocument @relation(fields: [documentId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([userId, documentId])
  @@index([userId, acceptedAt])
  @@map("user_consents")
}

model DataSubjectRequest {
  id           String                   @id @default(uuid()) @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  type         DataSubjectRequestType
  status       DataSubjectRequestStatus @default(PENDING)
  note         String?
  resolutionNote String?                @map("resolution_note")
  completedAt  DateTime?                @map("completed_at")
  reviewedById String?                  @map("reviewed_by_id") @db.Uuid
  user         User                     @relation(fields: [userId], references: [id])
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("data_subject_requests")
}

model DigitalFlyer {
  id          String      @id @default(uuid()) @db.Uuid
  businessId  String      @map("business_id") @db.Uuid
  title       String
  description String?
  imageUrl    String?     @map("image_url")
  actionUrl   String?     @map("action_url")
  status      FlyerStatus @default(DRAFT)
  startsAt    DateTime?   @map("starts_at")
  expiresAt   DateTime?   @map("expires_at")
  business    Business    @relation(fields: [businessId], references: [id])
  views       FlyerView[]
  pages       FlyerPage[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  @@index([businessId, status])
  @@index([status, expiresAt])
  @@map("digital_flyers")
}

model FlyerPage {
  id         String        @id @default(uuid()) @db.Uuid
  flyerId    String        @map("flyer_id") @db.Uuid
  imageUrl   String        @map("image_url")
  pageNumber Int           @map("page_number")
  flyer      DigitalFlyer  @relation(fields: [flyerId], references: [id])
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([flyerId, pageNumber])
  @@map("flyer_pages")
}

model FlyerView {
  id        String        @id @default(uuid()) @db.Uuid
  flyerId   String        @map("flyer_id") @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  source    String?
  flyer     DigitalFlyer  @relation(fields: [flyerId], references: [id])
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([flyerId, createdAt])
  @@map("flyer_views")
}

model SaveFoodPackage {
  id                String                @id @default(uuid()) @db.Uuid
  businessId        String                @map("business_id") @db.Uuid
  title             String
  description       String?
  imageUrl          String?               @map("image_url")
  originalPrice     Decimal?              @map("original_price") @db.Decimal(12, 2)
  pickupPrice       Decimal               @map("pickup_price") @db.Decimal(12, 2)
  currency          String                @default("RSD")
  quantityAvailable Int                   @default(0) @map("quantity_available")
  quantityTotal     Int                   @map("quantity_total")
  pickupStartAt     DateTime              @map("pickup_start_at")
  pickupEndAt       DateTime              @map("pickup_end_at")
  status            SaveFoodPackageStatus @default(DRAFT)
  business          Business              @relation(fields: [businessId], references: [id])
  reservations      SaveFoodReservation[]
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")

  @@index([businessId, status])
  @@index([status, pickupEndAt])
  @@map("save_food_packages")
}

model SaveFoodReservation {
  id          String                    @id @default(uuid()) @db.Uuid
  packageId   String                    @map("package_id") @db.Uuid
  userId      String                    @map("user_id") @db.Uuid
  quantity    Int
  status      SaveFoodReservationStatus @default(RESERVED)
  reservedAt  DateTime                  @default(now()) @map("reserved_at")
  cancelledAt DateTime?                 @map("cancelled_at")
  pickedUpAt  DateTime?                 @map("picked_up_at")
  package     SaveFoodPackage           @relation(fields: [packageId], references: [id])
  user        User                      @relation(fields: [userId], references: [id])
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([packageId, status])
  @@map("save_food_reservations")
}

model ContactInquiry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN")
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@map("contact_inquiries")
}
