model RewardBalance {
  userId        String      @id @map("user_id") @db.Uuid
  totalPoints   Int         @default(0) @map("total_points")
  level         RewardLevel @default(EXPLORER)
  referralCode  String      @unique @default(cuid()) @map("referral_code")
  user          User        @relation(fields: [userId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([level, totalPoints])
  @@map("reward_balances")
}

model RewardTransaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  eventType   RewardEventType @map("event_type")
  points      Int
  referenceId String          @map("reference_id")
  metadata    Json            @default("{}")
  user        User            @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now()) @map("created_at")

  @@unique([userId, eventType, referenceId])
  @@index([userId, createdAt])
  @@map("reward_transactions")
}

model RewardsCatalog {
  id                String   @id @default(uuid()) @db.Uuid
  businessId        String?  @map("business_id") @db.Uuid
  title             String
  description       String?
  imageUrl          String?  @map("image_url")
  pointsRequired    Int      @map("points_required")
  availableQuantity Int?     @map("available_quantity")
  isActive          Boolean  @default(true) @map("is_active")
  business          Business? @relation(fields: [businessId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  @@index([isActive, pointsRequired])
  @@map("rewards_catalog")
}

model Referral {
  id            String         @id @default(uuid()) @db.Uuid
  inviterId     String         @map("inviter_id") @db.Uuid
  invitedUserId String?        @unique @map("invited_user_id") @db.Uuid
  invitedEmail  String?        @map("invited_email")
  status        ReferralStatus @default(PENDING)
  inviter       User           @relation("referrals_sent", fields: [inviterId], references: [id])
  invitedUser   User?          @relation("referrals_received", fields: [invitedUserId], references: [id])
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@unique([inviterId, invitedEmail])
  @@index([inviterId, status])
  @@map("referrals")
}

model UserInterest {
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  score      Int      @default(1)
  user       User     @relation(fields: [userId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@id([userId, categoryId])
  @@index([categoryId, score])
  @@map("user_interests")
}

model Challenge {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String
  goal         Int
  rewardPoints Int     @map("reward_points")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(true) @map("is_active")
  participations ChallengeParticipation[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, endDate])
  @@map("challenges")
}

model ChallengeParticipation {
  userId      String    @map("user_id") @db.Uuid
  challengeId String    @map("challenge_id") @db.Uuid
  progress    Int       @default(0)
  completedAt DateTime? @map("completed_at")
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@id([userId, challengeId])
  @@map("challenge_participations")
}

model Partner {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  slug           String               @unique
  category       PartnerCategory
  level          PartnerLevel         @default(BRONZE)
  status         PartnerStatus        @default(PROSPECT)
  contactName    String?              @map("contact_name")
  contactEmail   String?              @map("contact_email")
  website        String?
  description    String?
  apiKeys        PartnerApiKey[]
  integrations   PartnerIntegration[]
  apiRequests    PartnerApiRequest[]
  webhooks       PartnerWebhookSubscription[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  @@index([status, level])
  @@index([category, status])
  @@map("partners")
}

model PartnerApiKey {
  id          String             @id @default(uuid()) @db.Uuid
  partnerId   String             @map("partner_id") @db.Uuid
  label       String
  keyPrefix   String             @map("key_prefix")
  keyHash     String             @unique @map("key_hash")
  scopes      Json               @default("[]")
  expiresAt   DateTime?          @map("expires_at")
  lastUsedAt  DateTime?          @map("last_used_at")
  revokedAt   DateTime?          @map("revoked_at")
  partner     Partner            @relation(fields: [partnerId], references: [id])
  requests    PartnerApiRequest[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@index([partnerId, revokedAt])
  @@map("partner_api_keys")
}

model PartnerIntegration {
  id            String                   @id @default(uuid()) @db.Uuid
  partnerId     String                   @map("partner_id") @db.Uuid
  name          String
  integrationType String                 @map("integration_type")
  status        PartnerIntegrationStatus @default(PLANNED)
  scopes        Json                     @default("[]")
  configuration Json                     @default("{}")
  startedAt     DateTime?                @map("started_at")
  partner       Partner                  @relation(fields: [partnerId], references: [id])
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  deletedAt     DateTime?                @map("deleted_at")

  @@index([partnerId, status])
  @@map("partner_integrations")
}

model PartnerApiRequest {
  id          String         @id @default(uuid()) @db.Uuid
  partnerId   String         @map("partner_id") @db.Uuid
  apiKeyId    String?        @map("api_key_id") @db.Uuid
  endpoint    String
  statusCode  Int            @map("status_code")
  partner     Partner        @relation(fields: [partnerId], references: [id])
  apiKey      PartnerApiKey? @relation(fields: [apiKeyId], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([partnerId, createdAt])
  @@map("partner_api_requests")
}

model PartnerWebhookSubscription {
  id                     String        @id @default(uuid()) @db.Uuid
  partnerId              String        @map("partner_id") @db.Uuid
  endpointUrl            String        @map("endpoint_url")
  eventTypes             Json          @default("[]") @map("event_types")
  signingSecretEncrypted String        @map("signing_secret_encrypted")
  status                 WebhookStatus @default(ACTIVE)
  lastFailureAt          DateTime?     @map("last_failure_at")
  partner                Partner       @relation(fields: [partnerId], references: [id])
  deliveries             PartnerWebhookDelivery[]
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")

  @@index([partnerId, status])
  @@map("partner_webhook_subscriptions")
}

model PartnerWebhookDelivery {
  id             String                 @id @default(uuid()) @db.Uuid
  subscriptionId String                 @map("subscription_id") @db.Uuid
  eventType      String                 @map("event_type")
  payload        Json                   @default("{}")
  status         WebhookDeliveryStatus  @default(PENDING)
  attempts       Int                    @default(0)
  responseStatus Int?                   @map("response_status")
  errorCode      String?                @map("error_code")
  deliveredAt    DateTime?              @map("delivered_at")
  subscription   PartnerWebhookSubscription @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@index([subscriptionId, status, createdAt])
  @@map("partner_webhook_deliveries")
}

model LegalDocument {
  id          String              @id @default(uuid()) @db.Uuid
  type        LegalDocumentType
  version     String
  locale      String              @default("sr")
  title       String
  content     String
  status      LegalDocumentStatus @default(DRAFT)
  publishedAt DateTime?           @map("published_at")
  consents    UserConsent[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  @@unique([type, version, locale])
  @@index([type, locale, status])
  @@map("legal_documents")
}

model UserConsent {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  documentId   String        @map("document_id") @db.Uuid
  source       String?
  acceptedAt   DateTime?     @map("accepted_at")
  withdrawnAt  DateTime?     @map("withdrawn_at")
  user         User          @relation(fields: [userId], references: [id])
  document     LegalDocument @relation(fields: [documentId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([userId, documentId])
  @@index([userId, acceptedAt])
  @@map("user_consents")
}

model DataSubjectRequest {
  id           String                   @id @default(uuid()) @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  type         DataSubjectRequestType
  status       DataSubjectRequestStatus @default(PENDING)
  note         String?
  resolutionNote String?                @map("resolution_note")
  completedAt  DateTime?                @map("completed_at")
  reviewedById String?                  @map("reviewed_by_id") @db.Uuid
  user         User                     @relation(fields: [userId], references: [id])
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("data_subject_requests")
}

model DigitalFlyer {
  id          String      @id @default(uuid()) @db.Uuid
  businessId  String      @map("business_id") @db.Uuid
  title       String
  description String?
  imageUrl    String?     @map("image_url")
  actionUrl   String?     @map("action_url")
  status      FlyerStatus @default(DRAFT)
  startsAt    DateTime?   @map("starts_at")
  expiresAt   DateTime?   @map("expires_at")
  business    Business    @relation(fields: [businessId], references: [id])
  views       FlyerView[]
  pages       FlyerPage[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  @@index([businessId, status])
  @@index([status, expiresAt])
  @@map("digital_flyers")
}

model FlyerPage {
  id         String        @id @default(uuid()) @db.Uuid
  flyerId    String        @map("flyer_id") @db.Uuid
  imageUrl   String        @map("image_url")
  pageNumber Int           @map("page_number")
  flyer      DigitalFlyer  @relation(fields: [flyerId], references: [id])
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([flyerId, pageNumber])
  @@map("flyer_pages")
}

model FlyerView {
  id        String        @id @default(uuid()) @db.Uuid
  flyerId   String        @map("flyer_id") @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  source    String?
  flyer     DigitalFlyer  @relation(fields: [flyerId], references: [id])
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([flyerId, createdAt])
  @@map("flyer_views")
}

model SaveFoodPackage {
  id                String                @id @default(uuid()) @db.Uuid
  businessId        String                @map("business_id") @db.Uuid
  title             String
  description       String?
  imageUrl          String?               @map("image_url")
  originalPrice     Decimal?              @map("original_price") @db.Decimal(12, 2)
  pickupPrice       Decimal               @map("pickup_price") @db.Decimal(12, 2)
  currency          String                @default("RSD")
  quantityAvailable Int                   @default(0) @map("quantity_available")
  quantityTotal     Int                   @map("quantity_total")
  pickupStartAt     DateTime              @map("pickup_start_at")
  pickupEndAt       DateTime              @map("pickup_end_at")
  status            SaveFoodPackageStatus @default(DRAFT)
  business          Business              @relation(fields: [businessId], references: [id])
  reservations      SaveFoodReservation[]
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")

  @@index([businessId, status])
  @@index([status, pickupEndAt])
  @@map("save_food_packages")
}

model SaveFoodReservation {
  id          String                    @id @default(uuid()) @db.Uuid
  packageId   String                    @map("package_id") @db.Uuid
  userId      String                    @map("user_id") @db.Uuid
  quantity    Int
  status      SaveFoodReservationStatus @default(RESERVED)
  pickupCode  String                    @unique @default(uuid()) @map("pickup_code")
  reservedAt  DateTime                  @default(now()) @map("reserved_at")
  cancelledAt DateTime?                 @map("cancelled_at")
  pickedUpAt  DateTime?                 @map("picked_up_at")
  package     SaveFoodPackage           @relation(fields: [packageId], references: [id])
  user        User                      @relation(fields: [userId], references: [id])
  review      SaveFoodReview?
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([packageId, status])
  @@map("save_food_reservations")
}

model SaveFoodReview {
  id            String                @id @default(uuid()) @db.Uuid
  reservationId String                @unique @map("reservation_id") @db.Uuid
  userId        String                @map("user_id") @db.Uuid
  rating        Int
  comment       String?
  reservation   SaveFoodReservation   @relation(fields: [reservationId], references: [id])
  user          User                  @relation(fields: [userId], references: [id])
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("save_food_reviews")
}

model ContactInquiry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN")
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@map("contact_inquiries")
}
